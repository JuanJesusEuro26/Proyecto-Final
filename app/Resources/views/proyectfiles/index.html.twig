{# Este será el index, la página principal de nuestro proyecto y que cargará los controladores necesarios según la acción del usuario. Se accederá mediante un controlador y tendrá aplicado el css y distintas configuraciones para que futuras páginas puedan heredar de él. #}

<!DOCTYPE html>
<html lang="en">
<head>
{% block head %}
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    {# Para el css usaremos bootstrap principalmente, aunque tambien podemos usar css normal en otras paginas. #}

    <script src="https://code.jquery.com/jquery-4.0.0.min.js" integrity="sha256-OaVG6prZf4v69dPg6PhVattBXkcOWQB62pdZ3ORyrao=" crossorigin="anonymous"></script>
    {#Para poder usar AJAX incluimos jquery#}
{% endblock %}
    <title>Index Proyecto Final</title> {# Obviamente dejamos el titulo fuera del bloque porque cada página tendrá el suyo propio#}
</head>

<body class="p-3 mb-2 bg-primary bg-opacity-50 text-primary-emphasis">
    <div>
        <header >
            <h1 class="text-center"><strong>Index Proyecto Final</strong></h1>
            <p class="text-center">Esta página contendrá enlaces a distintos controladores.</p>
            <hr class="border border-primary border-3 opacity-75">
        </header>

        <main >
           <div class="d-flex justify-content-center mt-5"> {# Esta funcion será la misma que en el proyectoinicial (busqueda de un pokemon usando pokeapi mediante curl) pero usando validators para el controlador, cargando un json en vez de otro html y haciendo uso de AJAX. La logica de entrar a la API debe estar manejada en un servicio aparte y se debe usar el controlador para incluir validator y procesar el codigo http que devuelve la pagina. #}
                <div class="card" style="min-width: 18rem; max-width: 40rem;">
                    <div class="card-header"><strong>Opcion 1</strong></div>
                        <form id="pokesearch_form">
                            <div class="card-body">
                                <h2 class="card-title">Formulario que busca un Pokemon.</h2>
                                <p class="card-text">Este formulario usa AJAX para buscar el pokemon e imprimirlo sin tener que reiniciar la pagina, renderizando respuestas JSON en vez de otra pagina diferente</p>
                                <input type="text" placeholder="Introduce un pokemon" id="pokemon_input" name="pokemon_input" class="form-control mb-2" required>
                                <button class="btn btn-primary" type="submit" id="btn_pokesearch">Buscar un pokemon</button>
                            </div>
                        </form>

                        <div id="resultado-pokemon" class="mt-4 text-center" style="display: none;">
                            <hr>
                            <h3 id="pk-nombre"></h3>
                            <p>ID: <span id="pk-id"></span></p>
                            <p>Tipo: <span id="pk-tipo"></span></p>
                            <img id="pk-foto" src="" alt="foto pokemon" class="img-fluid">
                        </div>
                        
                        <div id="error-message" class="alert alert-danger mt-3" style="display: none;"></div>
                </div>
            </div>
            


            {#<div class="d-flex justify-content-center mt-5">
                <div class="card" style="min-width: 18rem; max-width: 50rem;">
                    <div class="card-header"><strong>Opcion 1</strong></div>
                    <div class="card-body">
                        <h2 class="card-title">Formulario PHP que envía un correo.</h2>
                        <p class="card-text">Formulario PHP que envía un correo a través de una dirección de mail especificada en parameters.yml</p>
                        <a href="{{ path("") }}" class="btn btn-primary">Enviar un correo</a>
                    </div>
                </div>
            </div> Esta es una funcion que haré solo si me sobra tiempo en el futuro#}
        </main>

        <footer>

        </footer>

        <script>
            $(document).ready(function(){
                $("#resultado-pokemon").hide(); //Nos aseguramos de que el resultado no es visible al cargar la paágina

                $("#pokesearch_form").on("submit", function(e){ //Ponemos submit el form en vez de click al boton para que funcione el input required y no se recargue la pagina.
                    e.preventDefault(); //Prevenimos que la pagina se recargue al pulsar el boton 

                    $("#resultado-pokemon").hide();
                    $("#error-message").hide(); //Ocultamos el mensaje de error y el resultado por si alguno de estos estuviese activo
                    
                    // Corregido: añadido $ y corregido el selector
                    var nombrepk = $("#pokemon_input").val().trim();

                   /* if (nombrepk === "") { //Si el nombre del pokemon esta vacio, mandamos un error. En teoria no debe saltar nunca porque el input está required
                        $("#error-message").text("Escribe un nombre primero").fadeIn();
                        return;
                    }*/

                    // Corregido: Eliminado el ':' sobrante para que Twig no de error 500
                    var urlTemplate = "{{ path('PokeSearch', {'slug': 'Valor_reemplazable'}) }}";

                    // Corregido: Usamos urlTemplate (la variable de arriba) para hacer el reemplazo
                    var urlFinal = urlTemplate.replace('Valor_reemplazable', nombrepk);

                    $.ajax({
                        url: urlFinal,
                        type: "GET",
                        success: function(response){
                            //Si el post resulta exitoso cambiamos el valor de los datos del div resultado-pokemon por la informacion que devuelve el controlador
                            $("#pk-nombre").text(response.nombre);
                            $("#pk-id").text(response.id);
                            $("#pk-tipo").text(response.tipo);
                            $("#pk-foto").attr('src', response.foto);

                            //Desocultamos la info del pokemon
                            $("#resultado-pokemon").fadeIn();
                        },
                        error: function(fail){
                            //Ponemos un error default
                            var mensajeError="Error inesperado en la busqueda.";

                            //Si hay una respuesta JSON y encima es un error, cambiamos el mensaje por este error
                            if(fail.responseJSON && fail.responseJSON.error){
                                mensajeError=fail.responseJSON.error;
                            }

                            $("#error-message").text(mensajeError).fadeIn();
                            $("#resultado-pokemon").hide(); //Ocultamos el resultado del pokemon si hubiese alguno previamente
                        }
                    });
                });
            });
        </script>
    </div>
</body>
</html>